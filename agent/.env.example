# ══════════════════════════════════════════════════
# AgoraGuard Agent — Environment Variables
# ══════════════════════════════════════════════════
# Copy this file to .env and fill in your values
#   cp .env.example .env

# ── Blockchain ───────────────────────────────────
# Private key of the agent's wallet (required)
PRIVATE_KEY=0xYourPrivateKey

# Arc Testnet RPC URL (default shown)
ARC_RPC_URL=https://rpc.testnet.arc.network

# ── Smart Contracts ──────────────────────────────
# Deployed contract addresses from contracts/addresses.json
GUARDIAN_VAULT_ADDRESS=0x8de977504d2bff46ecfd153b10cdb9f22715f988
THREAT_REGISTRY_ADDRESS=0xef650672437a97a7b987984239064d502f56272d
RISK_GUARD_ORACLE_ADDRESS=0x2d101fafb24c660bfef07fd3106caf1074c80bf7

# ── Agent Config ─────────────────────────────────
# Cycle interval in seconds (default: 30)
CYCLE_INTERVAL_SECS=30

# Enable/disable AI-powered decisions (default: true)
AI_ENABLED=true

# Comma-separated token addresses to monitor (default: USDC, EURC)
MONITORED_TOKENS=0x3600000000000000000000000000000000000000,0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a

# Comma-separated wallet addresses to protect on HALT
PROTECTED_WALLETS=0xYourWallet1,0xYourWallet2

# Enables canteen.online status updates (default: false)
CANTEEN_UPDATES=false

# ── AI APIs ──────────────────────────────────────
# Anthropic Claude API key (for trading decisions)
ANTHROPIC_API_KEY=sk-ant-YourAnthropicKey

# GoPlus Security API key (for token threat checks)
GOPLUS_API_KEY=YourGoPlusKey

# ── Alert System ─────────────────────────────────
# Enable/disable the alert system (default: true)
ALERTS_ENABLED=true

# OpenAI API key (for generating alert messages and voice call scripts)
OPENAI_API_KEY=sk-YourOpenAIKey

# OpenAI model for alerts (default: gpt-4o-mini)
ALERTS_MODEL=gpt-4o-mini

# Cooldown between alerts for the same asset, in seconds (default: 300)
ALERTS_COOLDOWN_SECS=300

# Minimum caution flags required to trigger a CAUTION alert (default: 3)
ALERTS_CAUTION_FLAG_THRESHOLD=3

# Comma-separated Slack/Discord webhook URLs for alert notifications
ALERTS_WEBHOOK_URLS=https://hooks.slack.com/services/...,https://discord.com/api/webhooks/...

# ── Twilio Voice Calls ───────────────────────────
# Enable automated phone calls on risk alerts (default: false)
TWILIO_ENABLED=false

# Twilio account credentials (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YourTwilioAuthToken

# Twilio phone number to call FROM (must be a Twilio-purchased number)
TWILIO_FROM_PHONE=+15551234567

# Comma-separated phone numbers to call when an alert fires
TWILIO_TO_PHONES=+15559876543,+15551112222
